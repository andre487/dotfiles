#!/usr/bin/env python3
import os
import pathlib
import sys
from urllib.parse import urlsplit


def main():
    config_dir = pathlib.Path().home() / ".proxy487"
    proxy_list_file = config_dir / "proxy-list.txt"
    if not proxy_list_file.exists():
        halt("~/.proxy487/proxy-list.txt does not exist")

    chosen_file = config_dir / "chosen"
    chosen_host = None
    if chosen_file.exists():
        chosen_host = chosen_file.read_text().strip()

    if not config_dir.exists():
        config_dir.mkdir()

    proxies = proxy_list_file.read_text().strip().split("\n")
    if not proxies:
        halt("~/.proxy487/proxy-list.txt is empty")

    proxy = proxies[0]
    if chosen_host:
        for item in proxies:
            host = urlsplit(item).hostname
            if host == chosen_host:
                proxy = item
                break
        else:
            halt(f"{chosen_host} is not in ~/.proxy487/proxy-list.txt")

    if '?' in proxy:
        proxy = proxy.split('?', 1)[0]

    os.environ.update(
        http_proxy=proxy,
        https_proxy=proxy,
    )
    os.execvpe(sys.argv[1], sys.argv[1:], env=os.environ)


def halt(msg):
    print(msg, file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
